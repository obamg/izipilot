// ============================================================================
// schema.prisma — IziChange OKR SaaS
// Stack : Next.js 15 + PostgreSQL 16 + Prisma ORM
// Multi-tenant ready (orgId sur toutes les entités)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  CEO         // Accès total + pilotage global
  MANAGEMENT  // Vue synthèse + validation décisions
  PO          // Saisie hebdo + vue de son périmètre
  VIEWER      // Lecture seule
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum EntityType {
  COMPANY
  DEPARTMENT
  PRODUCT
}

enum Quarter {
  Q1
  Q2
  Q3
  Q4
}

enum KrType {
  NUMERIC       // Valeur chiffrée (ex: 500 traders)
  PERCENTAGE    // Pourcentage (ex: > 99.5% uptime)
  DATE          // Jalon (ex: go-live Avr 2026)
  BINARY        // Oui/Non (ex: licence obtenue)
}

enum KrStatus {
  ON_TRACK      // 🟢 En bonne voie (≥ 70%)
  AT_RISK       // 🟡 Attention (40–69%)
  BLOCKED       // 🔴 Bloqué (< 40%)
  NOT_STARTED   // ⚪ Non démarré
}

enum ProductStatus {
  ACTIVE
  IN_DEVELOPMENT
  PLANNED
  PAUSED
}

enum AlertType {
  KR_BLOCKED          // KR passé en rouge
  KR_DECLINING        // KR en baisse 2 semaines de suite
  ENTRY_MISSING       // PO n'a pas soumis sa revue lundi
  ESCALATION_48H      // Rouge non traité après 48h
  SCORE_BELOW_40      // Score < 40% pendant 3 semaines
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DecisionStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ActionStatus {
  TODO          // À faire
  IN_PROGRESS   // En cours
  BLOCKED       // Bloquée (avec raison)
  DONE          // Terminée
  CANCELLED     // Annulée
}

enum ActionPriority {
  LOW
  MEDIUM
  HIGH
  URGENT        // Liée à un KR rouge — auto-escalade
}

enum NotificationChannel {
  EMAIL
  IN_APP
}

enum NotificationType {
  WEEKLY_REMINDER     // Rappel lundi 8h30
  KR_BLOCKED_ALERT    // KR rouge → Management
  ESCALATION_48H      // Escalade 48h
  WEEKLY_DIGEST       // Digest hebdo Management
  DECISION_DUE        // Décision à rendre
}

enum SessionStatus {
  PENDING       // Pas encore ouverte
  OPEN          // Saisie en cours (lundi matin)
  CLOSED        // Deadline passée
  REVIEWED      // CODIR tenu
}

// ============================================================================
// ORGANISATION (Multi-tenant root)
// ============================================================================

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#008081")
  plan         Plan     @default(FREE)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  users          User[]
  departments    Department[]
  products       Product[]
  objectives     Objective[]
  keyResults     KeyResult[]
  weeklyEntries  WeeklyEntry[]
  weeklySessions WeeklySession[]
  alerts         Alert[]
  decisions      Decision[]
  actions        Action[]

  @@map("organizations")
}

// ============================================================================
// UTILISATEURS & AUTH
// ============================================================================

model User {
  id          String    @id @default(cuid())
  orgId       String
  email        String    @unique
  name         String
  passwordHash String?
  avatarUrl    String?
  role         UserRole  @default(VIEWER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  org              Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownedDepartments Department[]    @relation("DepartmentOwner")
  ownedProducts    Product[]       @relation("ProductOwner")
  ownedKeyResults  KeyResult[]     @relation("KrOwner")
  weeklyEntries    WeeklyEntry[]
  alerts           Alert[]         @relation("AlertTriggeredBy")
  resolvedAlerts   Alert[]         @relation("AlertResolvedBy")
  decisions        Decision[]      @relation("DecisionOwner")
  notifications    Notification[]
  sessions         Session[]
  assignedActions    Action[]           @relation("ActionAssignee")
  createdActions     Action[]           @relation("ActionCreator")
  actionComments     ActionComment[]    @relation("ActionCommentAuthor")
  departmentMembers  DepartmentMember[]

  @@index([orgId])
  @@index([email])
  @@map("users")
}

// NextAuth.js sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// PÉRIMÈTRE — DÉPARTEMENTS
// ============================================================================

model Department {
  id          String   @id @default(cuid())
  orgId       String
  code        String   // Ex: "D1", "D2"
  name        String   // Ex: "Communication & Marketing"
  color       String   // Hex IziChange palette
  description String?
  ownerId     String   // Responsable département
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner      User         @relation("DepartmentOwner", fields: [ownerId], references: [id])
  objectives Objective[]
  members    DepartmentMember[]

  @@unique([orgId, code])
  @@index([orgId])
  @@map("departments")
}

model DepartmentMember {
  id           String   @id @default(cuid())
  departmentId String
  userId       String
  role         String   @default("MEMBER") // MEMBER | LEAD
  joinedAt     DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([departmentId])
  @@index([userId])
  @@map("department_members")
}

// ============================================================================
// PÉRIMÈTRE — PRODUITS
// ============================================================================

model Product {
  id          String        @id @default(cuid())
  orgId       String
  code        String        // Ex: "P1", "P2"
  name        String        // Ex: "Plateforme Trading Crypto"
  color       String        // Hex IziChange palette
  description String?
  status      ProductStatus @default(ACTIVE)
  ownerId     String        // PO du produit
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner      User         @relation("ProductOwner", fields: [ownerId], references: [id])
  objectives Objective[]

  @@unique([orgId, code])
  @@index([orgId])
  @@map("products")
}

// ============================================================================
// OKR — OBJECTIFS
// ============================================================================

model Objective {
  id           String     @id @default(cuid())
  orgId        String
  // Lié à company, département ou produit
  entityType   EntityType
  departmentId String?
  productId    String?
  // Hiérarchie OKR (alignement vertical)
  parentId     String?
  title        String
  why          String?    // Pourquoi cet objectif ?
  quarter      Quarter
  year         Int        @default(2026)
  sortOrder    Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  department Department?  @relation(fields: [departmentId], references: [id])
  product    Product?     @relation(fields: [productId], references: [id])
  parent     Objective?   @relation("ObjectiveHierarchy", fields: [parentId], references: [id])
  children   Objective[]  @relation("ObjectiveHierarchy")
  keyResults KeyResult[]

  @@index([orgId])
  @@index([orgId, isActive])
  @@index([departmentId])
  @@index([productId])
  @@index([parentId])
  @@map("objectives")
}

// ============================================================================
// OKR — KEY RESULTS
// ============================================================================

model KeyResult {
  id          String   @id @default(cuid())
  orgId       String
  objectiveId String
  title       String
  krType      KrType   @default(NUMERIC)

  // Cible
  target      Float?   // Valeur cible (pour NUMERIC/PERCENTAGE)
  targetUnit  String?  // Ex: "$", "traders", "%", "resas"
  targetDate  String?  // Pour KrType.DATE (ex: "Avr 2026")

  // Scoring
  isInverse    Boolean     @default(false) // true = lower is better (ex: coût < 3$)
  currentValue Float       @default(0)
  score        Decimal     @default(0) @db.Decimal(5, 4) // 0.0000 à 1.0000
  status       KrStatus    @default(NOT_STARTED)

  // Méta
  ownerId     String   // PO responsable de ce KR
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  org           Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  objective     Objective     @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  owner         User          @relation("KrOwner", fields: [ownerId], references: [id])
  weeklyEntries WeeklyEntry[]
  alerts        Alert[]
  actions       Action[]

  @@index([orgId])
  @@index([objectiveId])
  @@index([ownerId])
  @@index([orgId, status])
  @@map("key_results")
}

// ============================================================================
// SAISIE HEBDOMADAIRE — WEEKLY ENTRY (par KR)
// ============================================================================

model WeeklyEntry {
  id          String   @id @default(cuid())
  orgId       String
  krId        String
  submittedBy String

  // Période
  weekNumber  Int      // 1–52 (ISO week)
  year        Int
  weekStart   DateTime // Lundi de la semaine

  // Saisie PO
  progress    Float    // % avancement réel (0.0 à 1.0)
  status      KrStatus
  delta       Float    @default(0) // Delta vs semaine précédente
  blocker          String?  // Blocage identifié
  proposedSolution String?  // Approche de solution (statut AT_RISK)
  actionNeeded     String?  // Besoin / décision requise
  comment          String?  // Commentaire libre

  // Calculs auto
  scoreAtEntry Decimal @default(0) @db.Decimal(5, 4)

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keyResult KeyResult    @relation(fields: [krId], references: [id], onDelete: Cascade)
  submitter User         @relation(fields: [submittedBy], references: [id])

  @@unique([krId, weekNumber, year])
  @@index([orgId])
  @@index([krId])
  @@index([submittedBy])
  @@index([orgId, weekNumber, year])
  @@map("weekly_entries")
}

// ============================================================================
// SESSION HEBDOMADAIRE GLOBALE
// ============================================================================

model WeeklySession {
  id          String        @id @default(cuid())
  orgId       String
  weekNumber  Int
  year        Int
  weekStart   DateTime      // Lundi 00:00
  deadline    DateTime      // Lundi 09:00 (deadline de saisie)
  status      SessionStatus @default(PENDING)
  notes       String?       // Notes du CODIR / stand-up
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  decisions Decision[]

  @@unique([orgId, weekNumber, year])
  @@index([orgId])
  @@map("weekly_sessions")
}

// ============================================================================
// ALERTES
// ============================================================================

model Alert {
  id          String        @id @default(cuid())
  orgId       String
  krId        String
  triggeredBy String        // userId qui a déclenché (ou "system")

  type        AlertType
  severity    AlertSeverity @default(HIGH)
  message     String

  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  resolution  String?  // Description de la résolution

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keyResult     KeyResult      @relation(fields: [krId], references: [id], onDelete: Cascade)
  triggerer     User           @relation("AlertTriggeredBy", fields: [triggeredBy], references: [id])
  resolver      User?          @relation("AlertResolvedBy", fields: [resolvedBy], references: [id])
  decisions     Decision[]
  notifications Notification[]

  @@index([orgId])
  @@index([krId])
  @@index([isResolved])
  @@index([orgId, type, isResolved])
  @@map("alerts")
}

// ============================================================================
// DÉCISIONS (actées en CODIR)
// ============================================================================

model Decision {
  id          String         @id @default(cuid())
  orgId       String
  alertId     String?
  sessionId   String?

  title       String
  description String?
  ownerId     String         // Responsable de la décision
  dueDate     DateTime?      // Date limite d'exécution
  status      DecisionStatus @default(OPEN)

  // Résolution
  outcome     String?        // Ce qui a été fait
  closedAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  alert   Alert?         @relation(fields: [alertId], references: [id])
  session WeeklySession? @relation(fields: [sessionId], references: [id])
  owner   User           @relation("DecisionOwner", fields: [ownerId], references: [id])

  @@index([orgId])
  @@index([ownerId])
  @@index([status])
  @@map("decisions")
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id      String              @id @default(cuid())
  userId  String
  alertId String?

  channel NotificationChannel
  type    NotificationType
  subject String
  body    String              @db.Text

  isSent  Boolean  @default(false)
  sentAt  DateTime?
  readAt  DateTime?

  createdAt DateTime @default(now())

  // Relations
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert Alert? @relation(fields: [alertId], references: [id])

  @@index([userId])
  @@index([isSent])
  @@index([userId, isSent])
  @@map("notifications")
}

// ============================================================================
// ACTIONS (suivi des tâches par Key Result)
// ============================================================================

model Action {
  id            String         @id @default(cuid())
  orgId         String
  krId          String
  title         String
  description   String?        @db.Text
  assigneeId    String
  createdById   String
  status        ActionStatus   @default(TODO)
  priority      ActionPriority @default(MEDIUM)
  dueDate       DateTime?
  completedAt   DateTime?
  weekCreated   Int            // Semaine ISO de création
  weekCompleted Int?           // Semaine ISO de complétion
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  // Relations
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keyResult KeyResult    @relation(fields: [krId], references: [id], onDelete: Cascade)
  assignee  User         @relation("ActionAssignee", fields: [assigneeId], references: [id])
  createdBy User         @relation("ActionCreator", fields: [createdById], references: [id])
  comments  ActionComment[]

  @@index([orgId])
  @@index([krId])
  @@index([assigneeId])
  @@index([orgId, status])
  @@map("actions")
}

model ActionComment {
  id        String   @id @default(cuid())
  actionId  String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  author User   @relation("ActionCommentAuthor", fields: [authorId], references: [id])

  @@index([actionId])
  @@index([authorId])
  @@map("action_comments")
}
